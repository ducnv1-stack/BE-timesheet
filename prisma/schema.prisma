// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 🟦 branches – Chi nhánh
model Branch {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  name      String
  address   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 🆕 GPS cho chấm công
  latitude      Float? // Vĩ độ trung tâm chi nhánh
  longitude     Float? // Kinh độ trung tâm chi nhánh
  checkinRadius Int    @default(70) @map("checkin_radius") // Bán kính cho phép (mét)

  branchType    BranchType @default(CHI_NHANH) @map("branch_type")
  
  employees          Employee[]
  orders             Order[]
  orderSplits        OrderSplit[]
  managerSalaryRules BranchManagerSalaryRule[]
  deliveryFeeRules   DeliveryFeeRule[]
  
  // 🆕 Relations cho tồn kho
  stocks             BranchStock[]
  stockItems         StockItem[]
  fromTransactions   StockTransaction[] @relation("FromBranch")
  toTransactions     StockTransaction[] @relation("ToBranch")

  // 🆕 Relations cho chấm công
  attendances Attendance[]
  workShifts  WorkShift[]

  @@map("branches")
}

enum BranchType {
  KHO_TONG
  CHI_NHANH
}

// 🟦 branch_stocks – Tồn kho tổng hợp theo chi nhánh
model BranchStock {
  id        String   @id @default(uuid()) @db.Uuid
  branchId  String   @map("branch_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  quantity  Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([branchId, productId])
  @@map("branch_stocks")
}

// 🟦 stock_items – Chi tiết từng máy theo Serial
model StockItem {
  id           String          @id @default(uuid()) @db.Uuid
  productId    String          @map("product_id") @db.Uuid
  branchId     String          @map("branch_id") @db.Uuid
  serialNumber String          @unique @map("serial_number")
  status       StockItemStatus @default(AVAILABLE)
  note         String?         @db.Text
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("stock_items")
}

enum StockItemStatus {
  AVAILABLE
  PENDING_TRANSFER
  SOLD
  RETRIEVED
  ERROR
}

// 🟦 stock_transactions – Nhật ký biến động kho
model StockTransaction {
  id           String          @id @default(uuid()) @db.Uuid
  code         String          @unique // NK..., XK..., CK..., TH...
  type         TransactionType
  fromBranchId String?         @map("from_branch_id") @db.Uuid
  toBranchId   String?         @map("to_branch_id") @db.Uuid
  productId    String          @map("product_id") @db.Uuid
  quantity     Int
  serialNumbers String[]        @default([]) @map("serial_numbers")
  note         String?         @db.Text
  createdBy    String          @map("created_by") @db.Uuid
  createdAt    DateTime        @default(now()) @map("created_at")

  fromBranch Branch? @relation("FromBranch", fields: [fromBranchId], references: [id])
  toBranch   Branch? @relation("ToBranch", fields: [toBranchId], references: [id])
  product    Product @relation(fields: [productId], references: [id])
  creator    User    @relation(fields: [createdBy], references: [id])

  @@map("stock_transactions")
}

enum TransactionType {
  IMPORT         // Nhập mới
  EXPORT         // Xuất kho
  TRANSFER       // Chuyển kho
  SALE           // Bán hàng (trừ kho)
  RETURN         // Khách trả hàng (hoàn kho)
  UPGRADE_RETURN // Thu hồi máy cũ từ đơn nâng cấp
  ADJUST         // Điều chỉnh kho (kiểm kho)
}

// 🟦 roles – Vai trò hệ thống
model Role {
  id   String @id @default(uuid()) @db.Uuid
  code String @unique // ADMIN, DIRECTOR, ACCOUNTANT_HQ, MANAGER, SALE, DRIVER...
  name String

  // 🆕 Cài đặt Lương mặc định theo Chức vụ
  baseSalary          Decimal? @map("base_salary") @db.Decimal(20, 2)
  diligentSalary      Decimal? @map("diligent_salary") @db.Decimal(20, 2)
  allowance           Decimal? @map("allowance") @db.Decimal(20, 2)
  standardWorkingDays Int?     @map("standard_working_days")

  users User[]

  @@map("roles")
}

// 🟦 users – Tài khoản đăng nhập
model User {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique
  passwordHash String   @map("password_hash")
  roleId       String   @map("role_id") @db.Uuid
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  role                 Role      @relation(fields: [roleId], references: [id])
  employee             Employee?
  ordersCreated        Order[]
  ordersConfirmed      Order[]   @relation("OrderConfirmer")
  ordersIssuedInvoices Order[]   @relation("OrderInvoiceIssuer")
  stockTransactions    StockTransaction[]
  attendanceAuditLogs  AttendanceAuditLog[]        @relation("AuditLogUser")
  exceptionApprovals   AttendanceExceptionRequest[] @relation("ExceptionApprover")
  approvedAttendances  Attendance[]                 @relation("AttendanceApprover")

  @@map("users")
}

// 🟦 employees – Nhân viên
model Employee {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String?   @unique @map("user_id") @db.Uuid
  branchId              String    @map("branch_id") @db.Uuid
  fullName              String    @map("full_name")
  phone                 String?
  position              String // sale, manager, telesale, driver... (Legacy) - WILL REMOVE LATER
  department            String? // Legacy - WILL REMOVE LATER
  
  // 🆕 Relations mới cho Chức vụ & Phòng ban
  positionId            String?   @map("position_id") @db.Uuid
  departmentId          String?   @map("department_id") @db.Uuid
  
  birthday              DateTime? @db.Date
  birthMonth            Int?      @map("birth_month")
  gender                String?
  status                String? // Đang làm việc, Nghỉ việc...
  workingType           String?   @map("working_type") // Hành chính, Full time...
  joinDate              DateTime? @map("join_date") @db.Date
  contractType          String?   @map("contract_type") // Hợp đồng 1 năm, Không xác định...
  contractSigningDate   DateTime? @map("contract_signing_date") @db.Date
  idCardNumber          String?   @unique @map("id_card_number")
  permanentAddress      String?   @map("permanent_address") @db.Text
  email                 String?
  socialInsuranceNumber String?   @map("social_insurance_number")
  isInternalDriver      Boolean   @default(false) @map("is_internal_driver")
  avatarUrl             String?   @map("avatar_url") // Link ảnh đại diện
  
  // 🆕 Chính sách chấm công riêng (Ngoại lệ)
  attendancePolicyId    String?   @map("attendance_policy_id") @db.Uuid

  // 🆕 Cài đặt Lương ngoại lệ cá nhân
  customBaseSalary          Decimal? @map("custom_base_salary") @db.Decimal(20, 2)
  customDiligentSalary      Decimal? @map("custom_diligent_salary") @db.Decimal(20, 2)
  customAllowance           Decimal? @map("custom_allowance") @db.Decimal(20, 2)
  customStandardWorkingDays Int?     @map("custom_standard_working_days")

  createdAt DateTime @default(now()) @map("created_at")

  user           User?                 @relation(fields: [userId], references: [id])
  branch         Branch                @relation(fields: [branchId], references: [id])
  pos            Position?             @relation(fields: [positionId], references: [id])
  dept           Department?           @relation(fields: [departmentId], references: [id])
  attendancePolicy AttendancePolicy?   @relation(fields: [attendancePolicyId], references: [id])
  splits         OrderSplit[]
  deliveries     Delivery[]
  marketingRules MarketingSalaryRule[]

  // 🆕 Relations cho chấm công
  attendances                Attendance[]
  leaveRequests              LeaveRequest[]
  monthlyAttendanceSummaries MonthlyAttendanceSummary[]
  exceptionRequests          AttendanceExceptionRequest[]

  @@map("employees")
}

// 🆕 Bảng Phòng ban
model Department {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  note      String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employees Employee[]

  @@map("departments")
}

// 🆕 Bảng Chức vụ
model Position {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String   @unique
  attendancePolicyId String?  @map("attendance_policy_id") @db.Uuid
  note               String?  @db.Text
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // 🆕 Cài đặt Lương mặc định theo Chức vụ
  baseSalary          Decimal? @map("base_salary") @db.Decimal(20, 2)
  diligentSalary      Decimal? @map("diligent_salary") @db.Decimal(20, 2)
  allowance           Decimal? @map("allowance") @db.Decimal(20, 2)
  standardWorkingDays Int?     @map("standard_working_days")

  attendancePolicy AttendancePolicy? @relation(fields: [attendancePolicyId], references: [id])
  employees        Employee[]

  @@map("positions")
}

// 🆕 Chính sách chấm công (Mẫu ca)
model AttendancePolicy {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique // Ví dụ: "Chính sách Sale", "Chính sách VP"
  note      String?  @db.Text
  
  // 🆕 GPS Overrides (Nếu có giá trị thì sẽ dùng thay cho GPS của Chi nhánh)
  latitude  Float?
  longitude Float?
  radius    Int?     @default(200) // Bán kính mặc định 200m
  requireGPS Boolean  @default(true) @map("require_gps")
  
  // 🆕 Cấu hình nâng cao dạng JSON Engine (Rule Engine)
  configData Json?    @map("config_data")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  days      AttendancePolicyDay[]
  positions Position[]
  employees Employee[]

  @@map("attendance_policies")
}

// 🆕 Chi tiết quy tắc từng ngày trong chính sách
model AttendancePolicyDay {
  id                 String   @id @default(uuid()) @db.Uuid
  attendancePolicyId String   @map("attendance_policy_id") @db.Uuid
  dayOfWeek          Int      // 0: Chủ nhật, 1: Thứ 2, ..., 6: Thứ 7
  startTime          String   @map("start_time") // "08:00"
  endTime            String   @map("end_time")   // "17:30"
  isOff              Boolean  @default(false) @map("is_off") // Ngày nghỉ (ví dụ CN là nghỉ)
  allowOT            Boolean  @default(false) @map("allow_ot") // Có tính tăng ca không
  otMultiplier       Decimal  @default(1.5) @map("ot_multiplier") @db.Decimal(3, 2) // Hệ số OT
  requireGPS         Boolean  @default(true) @map("require_gps") // Có bắt GPS không
  workCount          Decimal  @default(1.0) @map("work_count") @db.Decimal(3, 2) // Số công (ví dụ 1.0 hoặc 0.5)
  isFlexible         Boolean  @default(false) @map("is_flexible") // Chế độ linh hoạt (chỉ ghi nhận giờ, không tính muộn/sớm)

  policy AttendancePolicy @relation(fields: [attendancePolicyId], references: [id], onDelete: Cascade)
  attendances Attendance[]

  @@unique([attendancePolicyId, dayOfWeek])
  @@map("attendance_policy_days")
}

// 🟨 orders – Đơn hàng gốc
model Order {
  id                    String    @id @default(uuid()) @db.Uuid
  branchId              String    @map("branch_id") @db.Uuid
  customerName          String    @map("customer_name")
  customerPhone         String    @map("customer_phone")
  customerAddress       String?   @map("customer_address") @db.Text
  customerCardNumber    String?   @map("customer_card_number")
  customerCardIssueDate DateTime? @map("customer_card_issue_date") @db.Date
  staffCode             String?   @map("staff_code")
  orderDate             DateTime  @map("order_date") @db.Date
  orderSource           String    @map("order_source") // hotline, fanpage, vãng lai, giới thiệu
  status                String    @default("pending") // pending, assigned, delivered, canceled
  totalAmount           Decimal   @map("total_amount") @db.Decimal(20, 2)
  giftAmount            Decimal   @default(0) @map("gift_amount") @db.Decimal(20, 2)
  productBonusAmount    Decimal   @default(0) @map("product_bonus_amount") @db.Decimal(20, 2)
  note                  String?   @db.Text
  createdBy             String    @map("created_by") @db.Uuid
  isPaymentConfirmed    Boolean   @default(false) @map("is_payment_confirmed")
  confirmedById         String?   @map("confirmed_by_id") @db.Uuid
  confirmedAt           DateTime? @map("confirmed_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  images                String[]  @default([]) @map("images") // DS link ảnh biên lai, unc...

  // Upgrade logic fields
  isUpgrade                     Boolean  @default(false) @map("is_upgrade")
  oldOrderProductName           String?  @map("old_order_product_name")
  oldOrderAmount                Decimal? @map("old_order_amount") @db.Decimal(20, 2)
  oldOrderDate                  String?  @map("old_order_date")
  oldOrderCustomerName          String?  @map("old_order_customer_name")
  oldOrderCustomerPhone         String?  @map("old_order_customer_phone")
  oldOrderCustomerAddress       String?  @map("old_order_customer_address")
  oldOrderProvinceId            String?  @map("old_order_province_id") @db.Uuid
  oldOrderWardId                String?  @map("old_order_ward_id") @db.Uuid
  oldOrderCustomerCardNumber    String?  @map("old_order_customer_card_number")
  oldOrderCustomerCardIssueDate String?  @map("old_order_customer_card_issue_date")
  oldOrderId                    String?  @map("old_order_id") @db.Uuid
  oldOrderCode                  String?  @map("old_order_code")

  parentOrder  Order?  @relation("OrderUpgrades", fields: [oldOrderId], references: [id])
  upgradedFrom Order[] @relation("OrderUpgrades")

  // Added address fields
  provinceId String? @map("province_id") @db.Uuid
  wardId     String? @map("ward_id") @db.Uuid

  branch    Branch    @relation(fields: [branchId], references: [id])
  creator   User      @relation(fields: [createdBy], references: [id])
  confirmer User?     @relation("OrderConfirmer", fields: [confirmedById], references: [id])
  province  Province? @relation(fields: [provinceId], references: [id])
  ward      Ward?     @relation(fields: [wardId], references: [id])

  // VAT Invoice management
  isInvoiceIssued   Boolean   @default(false) @map("is_invoice_issued")
  invoiceIssuedAt   DateTime? @map("invoice_issued_at")
  invoiceIssuedById String?   @map("invoice_issued_by_id") @db.Uuid
  invoiceIssuer     User?     @relation("OrderInvoiceIssuer", fields: [invoiceIssuedById], references: [id])

  items      OrderItem[]
  splits     OrderSplit[]
  payments   Payment[]
  deliveries Delivery[]
  gifts      OrderGift[]
  auditLogs  OrderAuditLog[]

  @@map("orders")
}

// 🟨 order_items – Chi tiết sản phẩm
model OrderItem {
  id         String  @id @default(uuid()) @db.Uuid
  orderId    String  @map("order_id") @db.Uuid
  productId  String  @map("product_id") @db.Uuid
  quantity   Int
  unitPrice  Decimal @map("unit_price") @db.Decimal(20, 2)
  totalPrice Decimal @map("total_price") @db.Decimal(20, 2)

  // Snapshots for audit/salary
  minPriceAtSale     Decimal @map("min_price_at_sale") @db.Decimal(20, 2)
  isBelowMin         Boolean @map("is_below_min")
  bonusAmount        Decimal @default(0) @map("bonus_amount") @db.Decimal(20, 2)
  saleBonusAmount    Decimal @default(0) @map("sale_bonus_amount") @db.Decimal(20, 2)
  managerBonusAmount Decimal @default(0) @map("manager_bonus_amount") @db.Decimal(20, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// 🟨 order_splits – Chia doanh số
model OrderSplit {
  id           String  @id @default(uuid()) @db.Uuid
  orderId      String  @map("order_id") @db.Uuid
  employeeId   String  @map("employee_id") @db.Uuid
  branchId     String  @map("branch_id") @db.Uuid
  splitPercent Decimal @map("split_percent") @db.Decimal(5, 2)
  splitAmount  Decimal @map("split_amount") @db.Decimal(20, 2)

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branch   Branch   @relation(fields: [branchId], references: [id])

  @@map("order_splits")
}

// 🟨 payments – Thanh toán
model Payment {
  id            String   @id @default(uuid()) @db.Uuid
  orderId       String   @map("order_id") @db.Uuid
  paymentMethod String   @map("payment_method") // cash, transfer
  amount        Decimal  @db.Decimal(20, 2)
  paidAt        DateTime @map("paid_at") @db.Date

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// 🟨 deliveries – Giao hàng
model Delivery {
  id          String   @id @default(uuid()) @db.Uuid
  orderId     String   @map("order_id") @db.Uuid
  driverId    String?  @map("driver_id") @db.Uuid
  driverType  String   @map("driver_type") // internal | external | sale (Legacy - will be replaced by category)
  role        String?  @default("DRIVER") // DRIVER | STAFF
  category    String? // COMPANY_DRIVER, EXTERNAL_DRIVER, STAFF_DELIVERER, SELLING_SALE, OTHER_SALE
  deliveryFee Decimal  @map("delivery_fee") @db.Decimal(20, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  order  Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driver Employee? @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@map("deliveries")
}

// 5.1 Bảng products
model Product {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  minPrice  Decimal  @map("min_price") @db.Decimal(20, 2)
  isHighEnd Boolean  @default(false) @map("is_high_end")
  hotBonus  Decimal  @default(0) @map("hot_bonus") @db.Decimal(20, 2)
  createdAt DateTime @default(now()) @map("created_at")

  orderItems        OrderItem[]
  bonusPolicies     ProductBonusPolicy[]
  minPricePolicies  ProductMinPricePolicy[]
  branchStocks      BranchStock[]
  stockItems        StockItem[]
  stockTransactions StockTransaction[]

  @@map("products")
}

// 5.1.1 Bảng product_min_price_policies - Chính sách giá min theo thời gian
model ProductMinPricePolicy {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  minPrice  Decimal  @map("min_price") @db.Decimal(20, 2)
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime? @map("end_date") @db.Date
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, startDate, endDate])
  @@map("product_min_price_policies")
}

// 🟩 gifts – Quà tặng kèm
model Gift {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  price     Decimal  @default(0) @db.Decimal(20, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orderGifts OrderGift[]

  @@map("gifts")
}

// 🟩 order_gifts – Quà tặng trong đơn hàng
model OrderGift {
  id       String @id @default(uuid()) @db.Uuid
  orderId  String @map("order_id") @db.Uuid
  giftId   String @map("gift_id") @db.Uuid
  quantity Int    @default(1)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  gift  Gift  @relation(fields: [giftId], references: [id])

  @@map("order_gifts")
}

// 5.2 Bảng product_bonus_policies - Chính sách thưởng nóng theo thời gian
model ProductBonusPolicy {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  name      String?  @map("name")
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime? @map("end_date") @db.Date
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  rules   ProductBonusRule[]

  @@index([productId, startDate, endDate])
  @@map("product_bonus_policies")
}

// 5.3 Bảng product_bonus_rules - Chi tiết định mức thưởng
model ProductBonusRule {
  id             String  @id @default(uuid()) @db.Uuid
  policyId       String  @map("policy_id") @db.Uuid
  minSellPrice   Decimal @map("min_sell_price") @db.Decimal(20, 2)
  bonusAmount    Decimal @map("bonus_amount") @db.Decimal(20, 2)
  salePercent    Decimal @map("sale_percent") @db.Decimal(5, 2)
  managerPercent Decimal @map("manager_percent") @db.Decimal(5, 2)

  policy ProductBonusPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@map("product_bonus_rules")
}

// 🟥 sales_salary_rules
model SalesSalaryRule {
  id            String  @id @default(uuid()) @db.Uuid
  targetPercent Int     @map("target_percent")
  targetRevenue Decimal @map("target_revenue") @db.Decimal(20, 2)
  baseSalary    Decimal @map("base_salary") @db.Decimal(20, 2)
  bonusAmount   Decimal @map("bonus_amount") @db.Decimal(20, 2)

  @@map("sales_salary_rules")
}

// 🟥 branch_manager_salary_rules
model BranchManagerSalaryRule {
  id                String  @id @default(uuid()) @db.Uuid
  branchId          String  @map("branch_id") @db.Uuid
  targetPercent     Int     @map("target_percent")
  targetRevenue     Decimal @map("target_revenue") @db.Decimal(20, 2)
  baseSalary        Decimal @map("base_salary") @db.Decimal(20, 2)
  bonusAmount       Decimal @map("bonus_amount") @db.Decimal(20, 2)
  commissionPercent Decimal @map("commission_percent") @db.Decimal(5, 2)

  branch Branch @relation(fields: [branchId], references: [id])

  @@map("branch_manager_salary_rules")
}

// 🟥 telesale_salary_rules
model TelesaleSalaryRule {
  id                String  @id @default(uuid()) @db.Uuid
  commissionPercent Decimal @map("commission_percent") @db.Decimal(5, 2)

  @@map("telesale_salary_rules")
}

// 🟥 marketing_salary_rules
model MarketingSalaryRule {
  id                String  @id @default(uuid()) @db.Uuid
  employeeId        String  @map("employee_id") @db.Uuid
  revenueThreshold  Decimal @map("revenue_threshold") @db.Decimal(20, 0)
  commissionPercent Decimal @map("commission_percent") @db.Decimal(5, 2)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("marketing_salary_rules")
}

// 🟥 driver_salary_rules
model DriverSalaryRule {
  id            String  @id @default(uuid()) @db.Uuid
  driverType    String  @map("driver_type")
  amountPerTrip Decimal @map("amount_per_trip") @db.Decimal(20, 2)

  @@map("driver_salary_rules")
}

//  order_audit_logs
model OrderAuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  changedBy String   @map("changed_by") @db.Uuid
  action    String // create | update | delete
  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")
  changedAt DateTime @default(now()) @map("changed_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_audit_logs")
}

// 🏘️ provinces – Tỉnh/Thành phố
model Province {
  id    String @id @default(uuid()) @db.Uuid
  apiId String @unique @map("api_id")
  name  String
  wards Ward[]

  orders Order[]

  @@map("provinces")
}

// 🏘️ wards – Xã/Phường
model Ward {
  id         String @id @default(uuid()) @db.Uuid
  provinceId String @map("province_id") @db.Uuid
  name       String

  province Province @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@map("wards")
}

// 🕒 work_shifts – Ca làm việc
model WorkShift {
  id                   String  @id @default(uuid()) @db.Uuid
  branchId             String  @map("branch_id") @db.Uuid
  name                 String // "Ca hành chính", "Ca sáng", "Ca chiều"
  startTime            String  @map("start_time") // "08:00" (HH:mm)
  endTime              String  @map("end_time") // "17:30"
  breakMinutes         Int     @default(0) @map("break_minutes")
  lateThreshold        Int     @default(15) @map("late_threshold")
  lateSeriousThreshold Int     @default(30) @map("late_serious_threshold")
  earlyLeaveThreshold  Int     @default(15) @map("early_leave_threshold")
  isActive             Boolean @default(true) @map("is_active")

  branch      Branch       @relation(fields: [branchId], references: [id])
  attendances Attendance[]

  @@map("work_shifts")
}

// 📅 attendances – Bảng chấm công hàng ngày
model Attendance {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  branchId   String   @map("branch_id") @db.Uuid
  shiftId    String?  @map("shift_id") @db.Uuid
  date       DateTime @db.Date

  // --- CHECK-IN ---
  checkInTime        DateTime? @map("check_in_time")
  checkInLatitude    Float?    @map("check_in_latitude")
  checkInLongitude   Float?    @map("check_in_longitude")
  checkInDistance    Float?    @map("check_in_distance")
  checkInStatus      String?   @map("check_in_status")
  checkInMethod      String?   @map("check_in_method")
  checkInAttempts    Int       @default(0) @map("check_in_attempts")
  maxCheckInAttempts Int       @default(3) @map("max_check_in_attempts")

  // --- CHECK-OUT ---
  checkOutTime      DateTime? @map("check_out_time")
  checkOutLatitude  Float?    @map("check_out_latitude")
  checkOutLongitude Float?    @map("check_out_longitude")
  checkOutDistance  Float?    @map("check_out_distance")
  checkOutStatus    String?   @map("check_out_status")
  checkOutMethod    String?   @map("check_out_method")

  // --- TỔNG KẾT ---
  dailyStatus       String @default("ABSENT_UNAPPROVED") @map("daily_status")
  totalWorkMinutes  Int?   @map("total_work_minutes")
  overtimeMinutes   Int?   @map("overtime_minutes")
  lateMinutes       Int?   @map("late_minutes")
  earlyLeaveMinutes Int?   @map("early_leave_minutes")
  workCount         Decimal? @map("work_count") @db.Decimal(3, 2) // Số công: 1.0 (cả ngày), 0.5 (nửa ngày)

  attendancePolicyDayId String?  @map("attendance_policy_day_id") @db.Uuid
  
  note             String?  @db.Text
  isManualOverride Boolean  @default(false) @map("is_manual_override")
  approvedById     String?  @map("approved_by_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  auditLogs         AttendanceAuditLog[]
  exceptionRequests AttendanceExceptionRequest[]

  employee Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branch   Branch     @relation(fields: [branchId], references: [id])
  shift    WorkShift? @relation(fields: [shiftId], references: [id])
  policyDay AttendancePolicyDay? @relation(fields: [attendancePolicyDayId], references: [id])
  approver User?      @relation("AttendanceApprover", fields: [approvedById], references: [id])

  @@unique([employeeId, date])
  @@index([employeeId, date])
  @@index([branchId, date])
  @@map("attendances")
}

// 📝 leave_requests – Đơn xin nghỉ phép
model LeaveRequest {
  id           String    @id @default(uuid()) @db.Uuid
  employeeId   String    @map("employee_id") @db.Uuid
  leaveType    String    @map("leave_type")
  startDate    DateTime  @map("start_date") @db.Date
  endDate      DateTime  @map("end_date") @db.Date
  reason       String?   @db.Text
  status       String    @default("PENDING")
  approvedById String?   @map("approved_by_id") @db.Uuid
  approvedAt   DateTime? @map("approved_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("leave_requests")
}

// ⚙️ overtime_configs – Cấu hình tăng ca
model OvertimeConfig {
  id                 String  @id @default(uuid()) @db.Uuid
  name               String
  overtimeType       String  @map("overtime_type")
  multiplier         Decimal @db.Decimal(3, 1)
  minOvertimeMinutes Int     @default(30) @map("min_overtime_minutes")
  maxOvertimeMinutes Int     @default(240) @map("max_overtime_minutes")
  isActive           Boolean @default(true) @map("is_active")

  @@map("overtime_configs")
}

// 📊 monthly_attendance_summaries – Tổng hợp công tháng
model MonthlyAttendanceSummary {
  id         String @id @default(uuid()) @db.Uuid
  employeeId String @map("employee_id") @db.Uuid
  month      Int
  year       Int

  totalWorkDays        Int     @default(0) @map("total_work_days")
  fullDays             Int     @default(0) @map("full_days")
  halfDays             Int     @default(0) @map("half_days")
  absentApproved       Int     @default(0) @map("absent_approved")
  absentUnapproved     Int     @default(0) @map("absent_unapproved")
  lateDays             Int     @default(0) @map("late_days")
  totalLateMinutes     Int     @default(0) @map("total_late_minutes")
  earlyLeaveDays       Int     @default(0) @map("early_leave_days")
  totalOvertimeMinutes Int     @default(0) @map("total_overtime_minutes")
  totalWorkMinutes     Int     @default(0) @map("total_work_minutes")
  effectiveWorkDays    Decimal @default(0) @map("effective_work_days") @db.Decimal(5, 1)

  updatedAt DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
  @@map("monthly_attendance_summaries")
}

// 🚚 delivery_fee_rules – Quy tắc phí ship
model DeliveryFeeRule {
  id               String  @id @default(uuid()) @db.Uuid
  branchId         String? @map("branch_id") @db.Uuid
  deliveryCategory String  @map("delivery_category")
  feeAmount        Decimal @map("fee_amount") @db.Decimal(20, 2)
  isActive         Boolean @default(true) @map("is_active")

  branch Branch? @relation(fields: [branchId], references: [id])

  @@unique([branchId, deliveryCategory])
  @@map("delivery_fee_rules")
}

// 🆕 Nhật ký chỉnh sửa chấm công
model AttendanceAuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  attendanceId String   @map("attendance_id") @db.Uuid
  changedBy    String   @map("changed_by") @db.Uuid
  action       String   // e.g., "OVERRIDE_CHECK_IN", "SYSTEM_UPDATE"
  oldData      Json?    @map("old_data")
  newData      Json?    @map("new_data")
  reason       String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  user       User       @relation("AuditLogUser", fields: [changedBy], references: [id])

  @@map("attendance_audit_logs")
}

// 🆕 Đơn giải trình ngoại lệ (Báo muộn, về sớm, lỗi GPS...)
model AttendanceExceptionRequest {
  id           String    @id @default(uuid()) @db.Uuid
  employeeId   String    @map("employee_id") @db.Uuid
  attendanceId String?   @map("attendance_id") @db.Uuid
  date         DateTime  @db.Date
  type         String    // GO_LATE, LEAVE_EARLY, GPS_ERROR, FORGOT_CHECKIN, FORGOT_CHECKOUT
  reason       String    @db.Text
  images       String[]  @default([]) @map("images")
  status       String    @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedById String?   @map("approved_by_id") @db.Uuid
  approvedAt   DateTime? @map("approved_at")
  note         String?   @db.Text // Admin note
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  attendance Attendance? @relation(fields: [attendanceId], references: [id])
  approver   User?       @relation("ExceptionApprover", fields: [approvedById], references: [id])

  @@map("attendance_exception_requests")
}
